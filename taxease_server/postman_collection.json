{
	"info": {
		"_postman_id": "taxwise-jwt-auth-collection",
		"name": "TaxWise JWT Auth API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Register",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"dev@taxwise.com\",\n    \"password\": \"taxwise123\",\n    \"first_name\": \"Dev\",\n    \"last_name\": \"User\",\n    \"user_type\": \"individual\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/register/",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"register",
						""
					]
				}
			},
			"response": []
		},
		{
			"name": "2. Login (Obtain Tokens)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"pm.environment.set(\"access_token\", jsonData.access);",
							"pm.environment.set(\"refresh_token\", jsonData.refresh);",
							"pm.environment.set(\"user_email\", jsonData.user.email);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"dev@taxwise.com\",\n    \"password\": \"taxwise123\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/login/",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"login",
						""
					]
				}
			},
			"response": []
		},
		{
			"name": "3. Get Profile (Me)",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{access_token}}",
							"type": "string"
						}
					]
				},
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/me/",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"me",
						""
					]
				}
			},
			"response": []
		},
		{
			"name": "4. Update Profile (Me)",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{access_token}}",
							"type": "string"
						}
					]
				},
				"method": "PATCH",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"first_name\": \"Developer\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/me/",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"me",
						""
					]
				}
			},
			"response": []
		},
		{
			"name": "5. Token Refresh",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"refresh\": \"{{refresh_token}}\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/token/refresh/",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"token",
						"refresh",
						""
					]
				}
			},
			"response": []
		},
		{
			"name": "6. Logout (Blacklist)",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{access_token}}",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"refresh\": \"{{refresh_token}}\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/logout/",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"logout",
						""
					]
				}
			},
			"response": []
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"exec": [
					""
				],
				"type": "text/javascript"
			}
		},
		{
			"listen": "test",
			"script": {
				"exec": [
					""
				],
				"type": "text/javascript"
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000/api/accounts",
			"type": "string"
		}
	]
}